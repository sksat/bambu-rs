/target
**/*.rs.bk
*.pdb

# Claude Code runtime state (lock files, scheduled tasks)
/.claude

# Slicer (OrcaSlicer / BambuStudio CLI) output artifacts
/result.json
/*.gcode.3mf

# Local secrets / captured real-device fixtures that may contain access codes
/.bambu-local
/captures
# .env holds BAMBU_ACCESS_CODE and friends — never commit it
.env

# Web dashboard: build output (CI builds it; not committed) + node deps
/web/dist/*
!/web/dist/.gitkeep
/web/node_modules

# Stray ts-rs export dir from `cargo test --features ts-rs` without TS_RS_EXPORT_DIR
# (the canonical bindings live in web/src/bindings/, generated by `pnpm gen:types`).
/bindings/
